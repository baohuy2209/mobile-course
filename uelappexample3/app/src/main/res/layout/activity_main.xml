<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical" android:layout_marginTop="24dp" android:layout_marginHorizontal="24dp">
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#D04040"
        android:textSize="26sp"
        android:text="Event"
        android:onClick="project"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#2196F3"
        android:textSize="26sp"
        android:text="Event 2"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnVar1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FF5722"
        android:textSize="26sp"
        android:text="Variable Listener"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnVar2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FF9800"
        android:textSize="26sp"
        android:text="Variable Listener 2"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnImlement1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#D92674"
        android:textSize="26sp"
        android:text="Implement Listener"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnImlement2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#E71F4A"
        android:textSize="26sp"
        android:text="Implment Listener 2"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnClass1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#D92674"
        android:textSize="26sp"
        android:text="Class Listener 1"
        android:layout_marginTop="24dp" />
    <Button
        android:id="@+id/btnClass2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#E71F4A"
        android:textSize="26sp"
        android:text="Class Listener 2"
        android:layout_marginTop="24dp" />
</LinearLayout>