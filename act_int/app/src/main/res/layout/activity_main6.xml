<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:context=".MainActivity6">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THÔNG TIN BẢO HÀNH"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:textColor="@android:color/black"/>

        <!-- Thông tin khách hàng -->
        <EditText
            android:id="@+id/edtCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Họ và tên khách hàng"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Số điện thoại liên hệ"
            android:inputType="phone"
            android:layout_marginBottom="12dp"/>

        <!-- Thông tin sản phẩm -->
        <EditText
            android:id="@+id/edtProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên sản phẩm / Model"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtSerialNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Số Serial / IMEI"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/edtIssueDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mô tả tình trạng lỗi"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:lines="4"
            android:layout_marginBottom="20dp"/>

        <!-- Phần hình ảnh minh họa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hình ảnh minh họa sản phẩm"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnCaptureMultiple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm ảnh (Chụp/Tải lên)"
            android:layout_marginBottom="12dp"/>

        <!-- Khu vực hiển thị ảnh cuộn ngang -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#F0F0F0"
            android:padding="8dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/lnrImages"
                android:layout_width="wrap_content"
                android:layout_height="200dp"
                android:orientation="horizontal">

            </LinearLayout>
        </HorizontalScrollView>

        <Button
            android:id="@+id/btnSubmitWarranty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gửi yêu cầu bảo hành"
            android:backgroundTint="@color/design_default_color_primary"
            android:textColor="@android:color/white"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>