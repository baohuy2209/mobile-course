<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".film_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView14"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CheckboxExample"
            android:background="#009688"
            android:padding="16dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            />

        <TextView
            android:id="@+id/textView15"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn thích xem phim ở ứng dụng nào:"
            android:textSize="18sp"
            android:layout_margin="4dp"
            android:paddingBottom="4dp"
            android:textStyle="bold"/>

        <CheckBox
            android:id="@+id/chkfilm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Film+"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColorHighlight="#E04242"/>
        <CheckBox
            android:id="@+id/chkfptplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FPT play"
            android:textSize="16sp"
            android:textStyle="bold"/>
        <CheckBox
            android:id="@+id/chkCLipTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clip TV"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirm"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Confirm"
            android:gravity="center"
            android:layout_gravity="center"
            android:background="#009688"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp"
            />

        <TextView
            android:id="@+id/txt_ans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:background="#E77373"
            android:padding="8dp"
            android:textColor="@color/white"/>

    </LinearLayout>
</LinearLayout>