<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:padding="10dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/advertise_banner"/>
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:stretchColumns="*">
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/imvLunchBoxIcon"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/lunch_box_icon"/>
                <ImageView
                    android:id="@+id/imvNoodleIcon"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/noodle_icon"/>
                <ImageView
                    android:id="@+id/imvMilkteaIcon"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/milk_tea_icon" />
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/imvSnackIcon"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/snack_icon"/>
                <ImageView
                    android:id="@+id/imvKoreanIcon"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/korean_icon"/>
                <ImageView
                    android:id="@+id/imvHealthyIcon"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/healthy_icon" />
            </TableRow>
        </TableLayout>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:src="@drawable/baemin_studio_banner"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="100dp"
                android:src="@drawable/momo_service"/>
            <ImageView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="100dp"
                android:src="@drawable/zalopay_service"/>
        </LinearLayout>
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:padding="10dp">
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/tocotoco_promo"/>
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/share_tea_promo"/>
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/comebuy_promo"/>
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:src="@drawable/chaosuon_promo"/>
            </TableRow>
        </TableLayout>
    </LinearLayout>
</ScrollView>