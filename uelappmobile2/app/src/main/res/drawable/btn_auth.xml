<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer -->
    <item
        android:left="0dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1A000000" />
        </shape>
    </item>

    <!-- Button layer -->
    <item
        android:bottom="2dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#D53C3C" />
            <stroke
                android:width="0.5dp"
                android:color="#F4D0D0" />
        </shape>
    </item>

</layer-list>